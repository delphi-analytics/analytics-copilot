# ─── App ──────────────────────────────────────────────────────────────────────
APP_ENV=development
SECRET_KEY=change-me-32chars-minimum-required
DEBUG=true

# ─── Database (SQLite for dev, PostgreSQL for prod) ──────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./dvc.db
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/dvc

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── LLM Providers ────────────────────────────────────────────────────────────
# Groq (FREE) — get key at console.groq.com → API Keys → Create
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxx

# Optional premium providers
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# ─── LLM Model Configuration ─────────────────────────────────────────────────
LLM_FAST_MODEL=groq/llama-3.1-8b-instant         # Intent classification (free, fast)
LLM_SMART_MODEL=groq/llama-3.3-70b-versatile     # SQL generation, insights (free, smart)
LLM_PREMIUM_MODEL=anthropic/claude-sonnet-4-6    # Premium (optional, paid)
LLM_FALLBACK_MODEL=groq/llama-3.1-8b-instant

# ─── Vector Memory (optional) ────────────────────────────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_ENABLED=false

# ─── Integrations (optional) ─────────────────────────────────────────────────
SLACK_BOT_TOKEN=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# ─── Query Limits ─────────────────────────────────────────────────────────────
MAX_ROWS_RETURNED=10000
QUERY_TIMEOUT_SECONDS=30
